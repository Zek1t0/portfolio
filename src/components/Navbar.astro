---
import History from "../components/History.astro"
---
<div class="w-[350px] flex-col hidden lg:flex">
<div class="flex flex-col flex-1 gap-2">	
  <div class="bg-zinc-900 rounded-lg">
    <ul>
      <li>
        <a class="flex gap-4 text-zinc-400 hover:text-zinc-100 py-3.5 px-5 font-semibold transition-all duration-300">
          Home
        </a>
      </li>
      <li>
        <a class="flex gap-4 text-zinc-400 hover:text-zinc-100 py-3.5 px-5 font-semibold transition-all duration-300">
          Browse
        </a>
      </li>
    </ul>
  </div>
  <div class="bg-zinc-900 rounded-lg flex-1">
    <ul>
      <li>
        <a class="flex gap-4 text-zinc-400 hover:text-zinc-100 py-3.5 px-5 font-semibold transition-all duration-300">
          Recent History
        </a>
      </li>
    </ul>
    <ul class="pl-2">
      <History/>
    </ul>
  </div>
</div>
</div>