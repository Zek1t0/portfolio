---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Proficient">
  <main class="overflow-y-auto w-screen">
    <div class="rounded-lg bg-zinc-900 flex-1 mx-auto overflow-y-auto h-screen">
      <section class="w-full xl:w-6/12 hidden sm:block">
        <h2 class="text-2xl font-bold mb-1">About me</h2>
        <div> 
          <label for="tw-modal" class="cursor-pointer rounded h-[474px] bg-zinc-800 bg-gradient-to-t from-slate-950 flex">
            <p class="self-end px-4 pb-8 tracking-wide text-left antialiased font-medium">
              I am a frontend web developer, specializing in design and usability, while being open to adapting to any role in the job market, constantly seeking new challenges and learning experiences.
            </p>
          </label>
        </div>
        <input type="checkbox" id="tw-modal" class="peer fixed appearence-none opacity-0 cursor-pointer "/>
        <label for="tw-modal" 
         class="pointer-events-none invisible fixed inset-0 flex items-center justify-center overflow-hidden overscroll-contain
         bg-slate-700/30 opacity-0 transition-all duration-200 ease-in-out peer-checked:pointer-events-auto peer-checked:visible 
         peer-checked:opacity-100 peer-checked:[&>*]:translate-y-0 peer-checked:[&>*]:scale-100">
        <label class="max-h-[calc(100vh - 5em)] h-fit max-w-lg scale-90 overflow-y-auto overscroll-contain rounded-md bg-white p-6 text-black shadow-2xl transition" for="">
          <h3 class="text-lg font-bold">Modal opened!</h3>
          <p class="py-4"> Lorem ipsum dolor sit amet consectetur, adipisicing elit. Odit est neque aliquam, atque minus quae consectetur velit molestias inventore aspernatur quibusdam, blanditiis vero et, commodi ea quo nisi dolores debitis.</p>
